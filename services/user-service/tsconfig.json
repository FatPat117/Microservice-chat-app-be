{
  "extends": "../../tsconfig.base.json",
  "compilerOptions":{
    "rootDir":"src",
    "outDir":"dist",
    "tsBuildInfoFile":"dist/tsconfig.tsbuildinfo",
    "noImplicitAny": false,
    "declaration":true,
    "declarationMap":true,
    "composite":true,
    "baseUrl":".",
    "paths":{
      "@/*": ["src/*"]
    }
  },
  "include":["src"],
  "exclude":["dist","node_modules"]
}

